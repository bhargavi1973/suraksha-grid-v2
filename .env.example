# Copy these into your hosting platform's Environment Variables settings.
# Do NOT commit a real .env file with actual secrets to GitHub.
#
# You only need ONE of the three LLM provider blocks below -- whichever set
# of variables is present is what /api/llm will use automatically.
# Priority if multiple are set: Gemini > Groq > Azure (or force one with LLM_PROVIDER).

# --- Option A: Google Gemini (free tier, no billing setup) ---
# Get a free key at https://aistudio.google.com/apikey
# IMPORTANT: choose "Create API key in NEW project" -- keys tied to an
# existing Google Cloud project have sometimes shown limit:0 quota errors.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Option B: Groq (free tier, fast, OpenAI-compatible, reliable) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
# Groq's model lineup changes -- check https://console.groq.com for the
# current vision-capable model name if this default stops working.
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Option C: Azure OpenAI ---
# From Azure Portal -> your Azure OpenAI resource -> "Keys and Endpoint"
# IMPORTANT: copy the endpoint EXACTLY as shown there -- do not add any
# path after the domain (no /openai/deployments/..., no ?api-version=...,
# that part is built automatically). Just https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# --- Optional: force which provider to use if more than one is set above ---
# LLM_PROVIDER=groq

# --- Upstash Redis (storage) ---
# From https://console.upstash.com -> create a free Redis database -> REST API section
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
